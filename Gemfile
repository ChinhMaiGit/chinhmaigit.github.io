source "https://rubygems.org"

# Mirrors what GitHub Pages runs server-side (Jekyll + theme + plugins like
# jekyll-seo-tag and jekyll-github-metadata), so a local build matches the live site.
gem "github-pages", group: :jekyll_plugins

# Required to run `jekyll serve` on Ruby 3.0+ (webrick was removed from stdlib).
gem "webrick", "~> 1.8"
